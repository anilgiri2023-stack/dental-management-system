# Server Port
PORT=5000

# JWT Secret (change to a strong random string)
JWT_SECRET=your_jwt_secret_here

# Supabase (use SERVICE ROLE key from Dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Vercel may also use this shorter alias:
# SERVICE_ROLE_KEY=your_service_role_key_here

# SMTP (Gmail: use App Password, not regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Twilio SMS (sign up at twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Admin Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
