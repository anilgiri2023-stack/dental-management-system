# Server Port
PORT=5000

# JWT Secret (change to a strong random string)
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=https://your-frontend-domain.example
LOGO_URL=https://your-frontend-domain.example/favicon.svg

# Supabase (use SERVICE ROLE key from Dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SERVICE_ROLE_KEY=your_service_role_key_here
# Backward-compatible alias if your existing deployment already uses it:
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Email Service (Resend)
RESEND_API_KEY=re_your_api_key_here

# Twilio SMS (sign up at twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Admin Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
